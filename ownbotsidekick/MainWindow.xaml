<Window x:Class="ownbotsidekick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ownbotsidekick.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        FontFamily="Segoe UI Variable Text"
        Title="m'bot Trilby"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Loaded="Window_Loaded">
    <Grid x:Name="RootOverlayGrid"
          Visibility="{Binding OverlayVisibility}"
          Background="Transparent">
        <Border x:Name="OverlayPanelBorder"
                Margin="0"
                Background="{StaticResource OverlayBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="0"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#263242"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,2"
                                    Margin="0,0,10,0">
                                <TextBlock Text="m'bot"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="m'bot Trilby"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <UniformGrid Rows="1"
                                     Columns="3"
                                     Width="640"
                                     Height="86"
                                     HorizontalAlignment="Left">
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Quick Play 1" Click="QuickPlay1Button_Click" />
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Quick Play 2" Click="QuickPlay2Button_Click" />
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Quick Play 3" Click="QuickPlay3Button_Click" />
                        </UniformGrid>
                    </StackPanel>

                    <Grid Grid.Column="1" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock x:Name="ClipCountTextBlock"
                                       Text="{Binding ClipCountText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Button Content="Refresh"
                                    Style="{StaticResource TopBarButtonStyle}"
                                    Click="RefreshClipsButton_Click" />
                            <Button Content="X"
                                    Style="{StaticResource TopBarButtonStyle}"
                                    Width="32"
                                    Height="28"
                                    Padding="0"
                                    Margin="0"
                                    Click="CloseOverlayButton_Click" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Rows="1"
                                     Columns="2"
                                     Width="420"
                                     Height="86"
                                     Margin="0,10,0,0"
                                     HorizontalAlignment="Right">
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Play Random" Click="PlayRandomButton_Click" />
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Stop" Click="StopButton_Click" />
                        </UniformGrid>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <controls:SearchPanelControl x:Name="SearchPanel"
                                                 Grid.Column="0"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 SearchQueryDisplay="{Binding SearchQueryDisplay}"
                                                 VisibleClips="{Binding VisibleClips}"
                                                 NoResultsVisible="{Binding NoResultsVisible}"
                                                 Width="640"
                                                 Height="500" />

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding TopStatsTitle}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                <TextBlock Text="Scope"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TopStatsScopeMeButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Just me"
                                            Click="TopStatsScopeMeButton_Click" />
                                    <Button x:Name="TopStatsScopeServerButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Everyone"
                                            Click="TopStatsScopeGuildButton_Click" />
                                </StackPanel>

                                <TextBlock Text="Window"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,6,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TopStatsDays1Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="1D"
                                            Click="TopStatsDays1Button_Click" />
                                    <Button x:Name="TopStatsDays7Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="7D"
                                            Click="TopStatsDays7Button_Click" />
                                    <Button x:Name="TopStatsDays30Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="30D"
                                            Click="TopStatsDays30Button_Click" />
                                    <Button x:Name="TopStatsDaysAllButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="All time"
                                            Click="TopStatsDaysAllButton_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <TextBlock Text="{Binding TopStatsStatusText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,8" />
                                <Border Height="1"
                                        Width="90"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,22,0,0"
                                        Background="{StaticResource PanelBorderBrush}" />
                                <ScrollViewer Margin="0,22,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding TopClipStats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource TopClipStatButtonStyle}"
                                                        Tag="{Binding Trigger}"
                                                        Click="TopClipStatsItemButton_Click">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Trigger}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding PlayCountText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Normal"
                                                                   HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
