<Window x:Class="ownbotsidekick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ownbot Sidekick Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        PreviewMouseDown="Window_PreviewMouseDown"
        Loaded="Window_Loaded">
    <Grid x:Name="RootOverlayGrid"
          Background="Transparent">
        <Border x:Name="OverlayPanelBorder"
                HorizontalAlignment="Center"
                Width="1400"
                Margin="20"
                Background="#CC111111"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="Sidekick Overlay"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10" />
                        <UniformGrid Rows="1" Columns="3">
                            <Button Content="Clip A" Margin="4" Padding="8" Click="ClipAButton_Click" />
                            <Button Content="Clip B" Margin="4" Padding="8" Click="ClipBButton_Click" />
                            <Button Content="Clip C" Margin="4" Padding="8" Click="ClipCButton_Click" />
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <TextBlock x:Name="ClipCountTextBlock"
                                   Text="Clips: 0"
                                   Foreground="#DDFFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <Button Content="Refresh"
                                Padding="12,6"
                                Margin="0,0,10,0"
                                Click="RefreshClipsButton_Click" />
                        <Button Content="X"
                                Width="32"
                                Height="28"
                                Padding="0"
                                Click="CloseOverlayButton_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="640"
                            Background="#66000000"
                            BorderBrush="#66FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="SearchQueryTextBlock"
                                       Text="Start typing to search..."
                                       Foreground="#FFFFFFFF"
                                       FontSize="18"
                                       Margin="0,0,0,10" />

                            <UniformGrid x:Name="SearchResultsGrid"
                                         Grid.Row="1"
                                         Rows="4"
                                         Columns="3" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Log output"
                               FontSize="12"
                               Foreground="#DDFFFFFF"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Row="1"
                             MinHeight="0"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="#44000000"
                             Foreground="White"
                             BorderBrush="#66FFFFFF"
                             BorderThickness="1" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
