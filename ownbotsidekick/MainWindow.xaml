<Window x:Class="ownbotsidekick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        FontFamily="Segoe UI Variable Text"
        Title="ownbot Sidekick Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#D90F1217" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#D9222A36" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#503A4758" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E9EDF4" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A8B2C0" />
        <SolidColorBrush x:Key="AccentBrush" Color="#6A96FF" />
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#24303E" />
        <SolidColorBrush x:Key="ButtonBackgroundHoverBrush" Color="#2A3950" />
        <SolidColorBrush x:Key="ButtonBackgroundPressedBrush" Color="#223244" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#3A4C63" />
        <SolidColorBrush x:Key="ButtonBorderHoverBrush" Color="#6A96FF" />

        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ButtonBackgroundPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClipButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </Window.Resources>
    <Grid x:Name="RootOverlayGrid"
          Visibility="Collapsed"
          Background="Transparent">
        <Border x:Name="OverlayPanelBorder"
                Margin="0"
                Background="{StaticResource OverlayBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="0"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#263242"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,2"
                                    Margin="0,0,10,0">
                                <TextBlock Text="m'bot"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Sidekick Overlay"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <UniformGrid Rows="1" Columns="3">
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Clip A" Click="ClipAButton_Click" />
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Clip B" Click="ClipBButton_Click" />
                            <Button Style="{StaticResource ClipButtonStyle}" Content="Clip C" Click="ClipCButton_Click" />
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <TextBlock x:Name="ClipCountTextBlock"
                                   Text="Clips: 0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <Button Content="Refresh"
                                Style="{StaticResource TopBarButtonStyle}"
                                Click="RefreshClipsButton_Click" />
                        <Button Content="X"
                                Style="{StaticResource TopBarButtonStyle}"
                                Width="32"
                                Height="28"
                                Padding="0"
                                Margin="0"
                                Click="CloseOverlayButton_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="640"
                            Height="420"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="SearchQueryTextBlock"
                                       Text="Start typing to search..."
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <Grid Grid.Row="1">
                                <UniformGrid x:Name="SearchResultsGrid"
                                             Rows="4"
                                             Columns="3" />
                                <TextBlock x:Name="NoResultsTextBlock"
                                           Text="No results (press TAB to clear search)"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
