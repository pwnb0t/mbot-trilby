<UserControl x:Class="mbottrilby.Controls.SearchPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="640">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="SearchQueryTextBlock"
                       Text="Start typing to search..."
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <Grid Grid.Row="1">
                <UniformGrid x:Name="SearchResultsGrid"
                             Rows="5"
                             Columns="3" />
                <TextBlock x:Name="NoResultsTextBlock"
                           Text="No results (press TAB to clear search)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
