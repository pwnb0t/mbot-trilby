<Window x:Class="mbottrilby.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:mbottrilby.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        FontFamily="Segoe UI Variable Text"
        Title="m'bot Trilby"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Loaded="Window_Loaded">
    <Grid x:Name="RootOverlayGrid"
          Visibility="{Binding OverlayVisibility}"
          Background="Transparent">
        <Border x:Name="OverlayPanelBorder"
                Margin="0"
                Background="{StaticResource OverlayBackgroundBrush}"
                BorderThickness="0"
                CornerRadius="0"
                Padding="14">
            <Grid x:Name="OverlayLayoutGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderSectionGrid" Grid.Row="0" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="TopBarGrid" Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Background="#263242"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,2"
                                    Margin="0,0,10,0">
                                <TextBlock Text="m'bot"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="m'bot Trilby"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock x:Name="ClipCountTextBlock"
                                       Text="{Binding ClipCountText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Button Content="Refresh"
                                    Style="{StaticResource TopBarButtonStyle}"
                                    Click="RefreshClipsButton_Click" />
                            <Button Content="X"
                                    Style="{StaticResource TopBarButtonStyle}"
                                    Width="32"
                                    Height="28"
                                    Padding="0"
                                    Margin="0"
                                    Click="CloseOverlayButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="QuickPlayAndTransportGrid" Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="660" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                                      ItemsSource="{Binding QuickPlaySlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"
                                                 Columns="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Border Width="1536"
                                            HorizontalAlignment="Left"
                                            Background="Transparent">
                                        <ItemsPresenter />
                                    </Border>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="{Binding HotkeyLabel}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"
                                                   TextAlignment="Center" />
                                        <Button Height="86"
                                                Tag="{Binding SlotIndex}"
                                                Click="QuickPlayButton_Click"
                                                AllowDrop="True"
                                                DragEnter="QuickPlayButton_DragEnter"
                                                DragLeave="QuickPlayButton_DragLeave"
                                                DragOver="QuickPlayButton_DragOver"
                                                Drop="QuickPlayButton_Drop">
                                            <TextBlock Text="{Binding DisplayText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClipButtonStyle}">
                                                    <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDragHoverTarget}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDragAvailableTarget}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsAssigned}" Value="False">
                                                            <Setter Property="Background" Value="#AA1C2430" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid x:Name="TransportControlsGrid"
                              Grid.Column="1"
                              HorizontalAlignment="Right">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <UniformGrid Grid.Row="0"
                                         Rows="1"
                                         Columns="3"
                                         Width="660"
                                         Margin="0,0,0,6">
                                <TextBlock Text="Alt+-"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Alt+="
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Current Intro"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center" />
                            </UniformGrid>

                            <UniformGrid Grid.Row="1"
                                         Rows="1"
                                         Columns="3"
                                         Width="660"
                                         Height="86"
                                         HorizontalAlignment="Right">
                                <Button Style="{StaticResource ClipButtonStyle}" Content="Play Random" Click="PlayRandomButton_Click" />
                                <Button Style="{StaticResource ClipButtonStyle}" Content="Stop" Click="StopButton_Click" />
                                <Button x:Name="CurrentIntroButton"
                                        DataContext="{Binding CurrentIntroSlot}"
                                        Click="CurrentIntroButton_Click"
                                        AllowDrop="True"
                                        DragEnter="CurrentIntroButton_DragEnter"
                                        DragLeave="CurrentIntroButton_DragLeave"
                                        DragOver="CurrentIntroButton_DragOver"
                                        Drop="CurrentIntroButton_Drop">
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClipButtonStyle}">
                                            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDragHoverTarget}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDragAvailableTarget}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAssigned}" Value="False">
                                                    <Setter Property="Background" Value="#AA1C2430" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="MainContentGrid" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SharedTagWidgetPanel"
                            Grid.Column="0"
                            DataContext="{Binding SharedTagWidget}"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,12,0"
                            AllowDrop="True"
                            DragEnter="TagWidgetPanel_DragEnter"
                            DragLeave="TagWidgetPanel_DragLeave"
                            DragOver="TagWidgetPanel_DragOver"
                            Drop="TagWidgetPanel_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTagDragAvailableTarget}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTagDragHoverTarget}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid x:Name="SharedTagWidgetGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="5"
                                    Background="#AA1C2430"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Margin="2"
                                    Panel.ZIndex="20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTagDropActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TagDropHintText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="20" />
                            </Border>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding TitleText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Height="24"
                                           VerticalAlignment="Center" />

                                <Button x:Name="SharedTagWidgetPlayRandomButton"
                                        Grid.Column="1"
                                        Content="&#x1F500;"
                                        Style="{StaticResource TopBarButtonStyle}"
                                        Margin="8,0,0,0"
                                        Click="TagWidgetPlayRandomButton_Click"
                                        IsEnabled="{Binding HasSelectedTag}" />
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <ScrollViewer x:Name="SharedTagClipListScrollViewer"
                                          Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="SharedTagClipItemsControl" ItemsSource="{Binding Clips}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                                <Button Style="{StaticResource TopClipStatButtonStyle}"
                                                        Tag="{Binding Trigger}"
                                                        PreviewMouseLeftButtonDown="ClipDragSourceButton_PreviewMouseLeftButtonDown"
                                                        PreviewMouseLeftButtonUp="ClipDragSourceButton_PreviewMouseLeftButtonUp"
                                                        PreviewMouseMove="ClipDragSourceButton_PreviewMouseMove"
                                                        Click="TagClipItemButton_Click">
                                                <TextBlock Text="{Binding Trigger}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border x:Name="SharedTagDropZoneBorder"
                                    Grid.Row="3"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    AllowDrop="True"
                                    DragEnter="TagDropZone_DragEnter"
                                    DragLeave="TagDropZone_DragLeave"
                                    DragOver="TagDropZone_DragOver"
                                    Drop="TagDropZone_Drop">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#AA1C2430" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDragHoverTarget}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDragAvailableTarget}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding DropHintText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </Border>

                        </Grid>
                    </Border>

                    <Border x:Name="TagWidgetPanel"
                            Grid.Column="1"
                            DataContext="{Binding TagWidget}"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,12,0"
                            AllowDrop="True"
                            DragEnter="TagWidgetPanel_DragEnter"
                            DragLeave="TagWidgetPanel_DragLeave"
                            DragOver="TagWidgetPanel_DragOver"
                            Drop="TagWidgetPanel_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTagDragAvailableTarget}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTagDragHoverTarget}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid x:Name="TagWidgetGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="5"
                                    Background="#AA1C2430"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Margin="2"
                                    Panel.ZIndex="20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTagDropActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TagDropHintText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="20" />
                            </Border>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding TitleText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Height="24"
                                           VerticalAlignment="Center" />

                                <Button x:Name="TagWidgetPlayRandomButton"
                                        Grid.Column="1"
                                        Content="&#x1F500;"
                                        Style="{StaticResource TopBarButtonStyle}"
                                        Margin="8,0,0,0"
                                        Click="TagWidgetPlayRandomButton_Click"
                                        IsEnabled="{Binding HasSelectedTag}" />
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <ScrollViewer x:Name="TagClipListScrollViewer"
                                          Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="TagClipItemsControl" ItemsSource="{Binding Clips}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TopClipStatButtonStyle}"
                                                    Tag="{Binding Trigger}"
                                                    PreviewMouseLeftButtonDown="ClipDragSourceButton_PreviewMouseLeftButtonDown"
                                                    PreviewMouseLeftButtonUp="ClipDragSourceButton_PreviewMouseLeftButtonUp"
                                                    PreviewMouseMove="ClipDragSourceButton_PreviewMouseMove"
                                                    Click="TagClipItemButton_Click">
                                                <TextBlock Text="{Binding Trigger}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border x:Name="PersonalTagDropZoneBorder"
                                    Grid.Row="3"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    AllowDrop="True"
                                    DragEnter="TagDropZone_DragEnter"
                                    DragLeave="TagDropZone_DragLeave"
                                    DragOver="TagDropZone_DragOver"
                                    Drop="TagDropZone_Drop">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#AA1C2430" />
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDragHoverTarget}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ButtonBackgroundHoverBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDragAvailableTarget}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderHoverBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding DropHintText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </Border>

                        </Grid>
                    </Border>

                    <Grid x:Name="SearchAndDetailGrid"
                          Grid.Column="2"
                          Width="640"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="500" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="208" />
                        </Grid.RowDefinitions>

                        <controls:SearchPanelControl x:Name="SearchPanel"
                                                     Grid.Row="0"
                                                     SearchQueryDisplay="{Binding SearchQueryDisplay}"
                                                     VisibleSearchResults="{Binding VisibleSearchResults}"
                                                     NoResultsVisible="{Binding NoResultsVisible}" />

                        <Border x:Name="ClipDetailPanel"
                                Grid.Row="2"
                                Height="208"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding ClipDetail.TitleText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />

                                <Grid Grid.Row="1">
                                    <TextBlock Text="{Binding ClipDetail.StatusText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClipDetail.HasClip}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClipDetail.HasClip}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="94" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Trigger"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,8" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.TriggerText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Source"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,8" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.SourceUrlText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Start"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,8" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.StartOffsetText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Length"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,8" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.ClipLengthText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="0"
                                                   Text="Added by"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="4"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.AddedByText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="5"
                                                   Grid.Column="0"
                                                   Text="Tags"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="5"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.TagsText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClipDetail.HasTag}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="94" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Tag"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,8" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.TriggerText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Clips"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Top" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding ClipDetail.TagClipListText}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Top" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="RecentClipsPanel"
                            Grid.Column="3"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="12,0,0,0">
                        <Grid x:Name="RecentClipsGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding RecentStatsTitle}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Height="24"
                                       Margin="0,0,0,10" />

                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                <TextBlock Text="Filters"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Height="16"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal" Height="30">
                                    <Button x:Name="RecentStatsScopeMeButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Just me"
                                            Click="RecentStatsScopeMeButton_Click" />
                                    <Button x:Name="RecentStatsScopeEveryoneButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Everyone"
                                            Click="RecentStatsScopeEveryoneButton_Click" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Height="30" Margin="0,6,0,0">
                                    <Button x:Name="RecentStatsIncludeRandomButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Include random"
                                            Click="RecentStatsIncludeRandomButton_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Grid x:Name="RecentClipsContentGrid" Grid.Row="2">
                                <TextBlock Text="{Binding RecentStatsStatusText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,8" />
                                <Border Height="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Margin="14,0,14,0"
                                        Background="{StaticResource TextSecondaryBrush}" />
                                <ScrollViewer x:Name="RecentClipsScrollViewer"
                                              Margin="0,22,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="RecentClipsItemsControl" ItemsSource="{Binding RecentClipStats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                  <Button Style="{StaticResource TopClipStatButtonStyle}"
                                                          Tag="{Binding Trigger}"
                                                          PreviewMouseLeftButtonDown="ClipDragSourceButton_PreviewMouseLeftButtonDown"
                                                          PreviewMouseLeftButtonUp="ClipDragSourceButton_PreviewMouseLeftButtonUp"
                                                          PreviewMouseMove="ClipDragSourceButton_PreviewMouseMove"
                                                          Click="RecentClipStatsItemButton_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="{Binding TriggerDisplay}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="1"
                                                                   Text="&#x1F500;"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="Normal"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Top"
                                                                   Margin="8,0,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRandom}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="0"
                                                                   Text="{Binding RequesterDisplayName}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Normal"
                                                                   HorizontalAlignment="Left"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,8,0" />
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Text="{Binding PlayedAgoText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Normal"
                                                                   HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="TopClipsPanel"
                            Grid.Column="4"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="12,0,0,0">
                        <Grid x:Name="TopClipsGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{Binding TopStatsTitle}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Height="24"
                                       Margin="0,0,0,10" />

                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                <TextBlock Text="Filters"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Height="16"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal" Height="30">
                                    <Button x:Name="TopStatsScopeMeButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Just me"
                                            Click="TopStatsScopeMeButton_Click" />
                                    <Button x:Name="TopStatsScopeServerButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="Everyone"
                                            Click="TopStatsScopeGuildButton_Click" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Height="30" Margin="0,6,0,0">
                                    <Button x:Name="TopStatsDays1Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="1D"
                                            Click="TopStatsDays1Button_Click" />
                                    <Button x:Name="TopStatsDays7Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="7D"
                                            Click="TopStatsDays7Button_Click" />
                                    <Button x:Name="TopStatsDays30Button"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="30D"
                                            Click="TopStatsDays30Button_Click" />
                                    <Button x:Name="TopStatsDaysAllButton"
                                            Style="{StaticResource StatsFilterButtonStyle}"
                                            Content="All time"
                                            Click="TopStatsDaysAllButton_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Grid x:Name="TopClipsContentGrid" Grid.Row="2">
                                <TextBlock Text="{Binding TopStatsStatusText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,8" />
                                <Border Height="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Margin="14,0,14,0"
                                        Background="{StaticResource TextSecondaryBrush}" />
                                <ScrollViewer x:Name="TopClipsScrollViewer"
                                              Margin="0,22,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="TopClipsItemsControl" ItemsSource="{Binding TopClipStats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                  <Button Style="{StaticResource TopClipStatButtonStyle}"
                                                          Tag="{Binding Trigger}"
                                                          PreviewMouseLeftButtonDown="ClipDragSourceButton_PreviewMouseLeftButtonDown"
                                                          PreviewMouseLeftButtonUp="ClipDragSourceButton_PreviewMouseLeftButtonUp"
                                                          PreviewMouseMove="ClipDragSourceButton_PreviewMouseMove"
                                                          Click="TopClipStatsItemButton_Click">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding Trigger}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding PlayCountText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Normal"
                                                                   HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
