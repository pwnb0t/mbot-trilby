<Window x:Class="mbottrilby.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trilby Settings"
        Width="500"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Trilby Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TabControl Grid.Row="1">
            <TabItem Header="Connection">
                <Grid Margin="12,10,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="EnvironmentRowDefinition" Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="EnvironmentPanel"
                                Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <TextBlock Text="Environment"
                                   Width="110"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="EnvironmentComboBox"
                                  Width="300"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Name"
                                  SelectionChanged="EnvironmentComboBox_SelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock x:Name="BaseUrlTextBlock" Margin="0,0,0,6" />
                        <TextBlock x:Name="AuthStatusTextBlock" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Server"
                                   Width="110"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="ServerComboBox"
                                  Width="300"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="GuildId"
                                  SelectionChanged="ServerComboBox_SelectionChanged" />
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               x:Name="InfoTextBlock"
                               TextWrapping="Wrap"
                               Foreground="DimGray" />

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button x:Name="OpenClipBrowserButton"
                                Width="140"
                                Margin="0,0,8,0"
                                Content="Open Clip Browser"
                                Click="OpenClipBrowserButton_Click" />
                        <Button x:Name="SignInButton" Width="110" Margin="0,0,8,0" Content="Sign In" Click="SignInButton_Click" />
                        <Button x:Name="SignOutButton" Width="110" Content="Sign Out" Click="SignOutButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Updates">
                <Grid Margin="12,10,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="VersionTextBlock"
                               Grid.Row="0"
                               Margin="0,0,0,12"
                               FontWeight="SemiBold" />

                    <Button x:Name="CheckForUpdatesButton"
                            Grid.Row="1"
                            Width="160"
                            HorizontalAlignment="Left"
                            Content="Check for updates"
                            Click="CheckForUpdatesButton_Click" />

                    <TextBlock x:Name="UpdateStatusTextBlock"
                               Grid.Row="2"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Foreground="DimGray" />
                </Grid>
            </TabItem>

            <TabItem Header="Options">
                <Grid Margin="12,10,12,12">
                    <StackPanel VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="OpaqueBackgroundCheckBox"
                                      Content="Opaque background"
                                      VerticalAlignment="Center"
                                      Checked="OpaqueBackgroundCheckBox_Changed"
                                      Unchecked="OpaqueBackgroundCheckBox_Changed" />
                            <Border Margin="8,0,0,0"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#FFF0F0F0"
                                    BorderBrush="#FFB8B8B8"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTip="When enabled, Trilby fills the full overlay background instead of leaving the surrounding area transparent. This is useful for screenshots.">
                                <TextBlock Text="?"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="DimGray"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <CheckBox x:Name="DoNotHideWhenPlayingClipCheckBox"
                                      Content="Do not hide when playing a clip"
                                      VerticalAlignment="Center"
                                      Checked="DoNotHideWhenPlayingClipCheckBox_Changed"
                                      Unchecked="DoNotHideWhenPlayingClipCheckBox_Changed" />
                            <Border Margin="8,0,0,0"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    Background="#FFF0F0F0"
                                    BorderBrush="#FFB8B8B8"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    ToolTip="Useful for when you want to do a bunch of clip management">
                                <TextBlock Text="?"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="DimGray"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Width="140" Content="Minimize to tray" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
